{
  "JwtSettings": {
    "SecretKey": "CHANGE_THIS_TO_A_LONG_RANDOM_SECRET_KEY_IN_PRODUCTION_MIN_32_CHARS",
    "Issuer": "PMS-IdentityService",
    "Audience": "PMS-Services",
    "AccessTokenExpiryMinutes": 15,
    "RefreshTokenExpiryDays": 7
  },
  "KafkaSettings": {
    "BootstrapServers": "localhost:9092",
    "GroupId": "identity-service"
  },
  "ServiceUrls": {
    "CollegeService": "http://localhost:5002",
    "NotificationService": "http://localhost:5006"
  },
  "ConnectionStrings": {
    "IdentityDb": "Host=localhost;Port=5432;Database=pms_identity;Username=pms_user;Password=pms_password"
  },
  "AppSettings": {
    "FrontendBaseUrl": "http://localhost:5173"
  },
  "AllowedOrigins": "http://localhost:3000,http://localhost:5173",
  "ServiceClients": {
    "CollegeService": {
      "ClientId": "college-service",
      "ClientSecret": "college-service-secret-key-change-in-production"
    },
    "StudentService": {
      "ClientId": "student-service",
      "ClientSecret": "student-service-secret-key-change-in-production"
    },
    "DriveService": {
      "ClientId": "drive-service",
      "ClientSecret": "drive-service-secret-key-change-in-production"
    },
    "NotificationService": {
      "ClientId": "notification-service",
      "ClientSecret": "notification-service-secret-key-change-in-production"
    }
  },
  "Serilog": {
    "MinimumLevel": {
      "Default": "Information",
      "Override": {
        "Microsoft": "Warning",
        "Microsoft.EntityFrameworkCore": "Warning",
        "System": "Warning"
      }
    }
  },
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning"
    }
  }
}